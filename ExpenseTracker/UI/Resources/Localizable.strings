/* FAQ */
"faq_q1" = "Как добавить новую транзакцию?";
"faq_a1" = "Нажмите на большую кнопку '+' внизу экрана. Выберите тип транзакции (расход или доход), укажите сумму, категорию и дату. Нажмите 'Сохранить'.";
"faq_q2" = "Как создать новую категорию?";
"faq_a2" = "Перейдите в Настройки → Категории → нажмите '+' в правом верхнем углу. Введите название, выберите иконку и цвет для категории.";
"faq_q3" = "Как изменить валюту?";
"faq_a3" = "Откройте Настройки → Валюта по умолчанию → выберите нужную валюту из списка. Все суммы будут отображаться в выбранной валюте.";
"faq_q4" = "Безопасны ли мои данные?";
"faq_a4" = "Да! Все данные хранятся локально на вашем устройстве и шифруются. Мы не передаем ваши данные третьим лицам. Опционально можно включить синхронизацию через iCloud.";
"faq_q5" = "Как посмотреть статистику?";
"faq_a5" = "Откройте вкладку 'Статистика' внизу экрана. Вы увидите круговую диаграмму расходов по категориям и детальную статистику за выбранный период.";
"faq_q6" = "Можно ли экспортировать данные?";
"faq_a6" = "Да, вы можете экспортировать все транзакции в формате CSV или PDF. Перейдите в Настройки → Экспорт данных.";
"faq_q7" = "Как удалить транзакцию?";
"faq_a7" = "Нажмите на транзакцию в списке, затем нажмите кнопку 'Редактировать'. В открывшемся окне внизу есть кнопка 'Удалить транзакцию'.";
"faq_q8" = "Работает ли приложение офлайн?";
